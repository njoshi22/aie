# Copy to .env (gitignored) and fill in.

GEMINI_API_KEY=

# Canonical RevMem API. Leave empty for offline stub mode.
REVMEM_BASE_URL=http://127.0.0.1:8000

# Set to 1 only when you intentionally want stub responses even with a base URL.
REVMEM_STUB_MODE=0

REVMEM_TOOL_TRANSPORT=mcp
REVMEM_PORT=8000

# Demo isolation and live hosted-agent visibility.
REVMEM_DB=/tmp/revmem-demo.db
REVMEM_STREAM=1
