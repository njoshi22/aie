# Person C - CLI + email approval. Copy to .env (gitignored) and fill in.

# Resend (omit to run the email step as a console dry-run)
RESEND_API_KEY=
REVMEM_FROM_EMAIL=onboarding@resend.dev

# Where the Approve magic link points (the notify.approve endpoint)
APPROVAL_BASE_URL=http://localhost:8000

# Local approval store (scaffold; swap for Atlas at integration)
REVMEM_APPROVALS_PATH=.revmem_approvals.json
